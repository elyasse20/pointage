generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS POUR LIMITER LES VALEURS AUTORISÉES
// ==========================================

enum Role {
  admin
  employe
}

enum PointageType {
  entree
  sortie
}

enum CongeType {
  annuel
  maladie
  exceptionnel
}

enum CongeStatut {
  en_attente
  valide
  refuse
}

// ==========================================
// MODÈLES (SCHEMAS)
// ==========================================

model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  nom       String
  email     String     @unique // Validation: Email unique
  password  String     // Doit être hashé dans la logique métier
  role      Role

  // Relations (One-to-Many)
  pointages Pointage[]
  conges    Conge[]

  @@map("users") // Nom exact de la collection dans MongoDB
}

model Pointage {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  
  // Relation avec User
  user_id   String       @db.ObjectId
  user      User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  date      String       // Format YYYY-MM-DD
  heure     String       // Format HH:MM
  type      PointageType
  latitude  String?      // Optionnel
  longitude String?      // Optionnel
  valide    Boolean?     @default(false) // Validation explicite ou valeur par défaut

  @@map("pointages")
}

model Conge {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  
  // Relation avec User
  user_id    String      @db.ObjectId
  user       User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  date_debut DateTime
  date_fin   DateTime
  type       CongeType
  statut     CongeStatut @default(en_attente) // Valeur par défaut "en_attente"

  @@map("conges")
}
